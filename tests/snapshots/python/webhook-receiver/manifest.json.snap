{
  "$schema": "./schema/piphi-manifest.schema.json",
  "manifest_version": "1.0",
  "id": "python-webhook-receiver-runtime",
  "name": "Python Webhook Receiver Runtime",
  "version": "0.1.0",
  "description": "Starter PiPhi integration runtime generated by piphi-network-create using the webhook-receiver preset for cloud-api.",
  "metadata": {
    "generator": "piphi-network-create",
    "scaffold_version": "0.2.0",
    "preset": "webhook-receiver",
    "domain": "cloud-api",
    "preset_summary": "Webhook receiver starter with signed inbound event handling."
  },
  "maintainer": {
    "name": "PiPhi Network",
    "website": "https://piphi.io"
  },
  "license": "Apache-2.0",
  "image": "piphinetwork/python-webhook-receiver-runtime:0.1.0",
  "platforms": [
    "linux"
  ],
  "runtime": {
    "linux": {
      "type": "container",
      "container": {
        "image": "piphinetwork/python-webhook-receiver-runtime:0.1.0",
        "ports": [
          {
            "container": 9988,
            "host": 9988
          }
        ],
        "environment": {
          "LOG_LEVEL": "info"
        },
        "restart_policy": {
          "name": "unless-stopped",
          "maximum_retry_count": 0
        }
      },
      "discovery": {
        "method": "passive"
      }
    }
  },
  "api": {
    "required": [
      "health",
      "entities",
      "command",
      "config",
      "ui_config"
    ],
    "endpoints": {
      "health": "/health",
      "diagnostics": "/diagnostics",
      "discover": "/discover",
      "entities": "/entities",
      "state": "/state",
      "config": "/config",
      "config_sync": "/config/sync",
      "deconfigure": "/deconfigure",
      "ui_config": "/ui-config",
      "events": "/events",
      "command": "/command"
    }
  },
  "config": {
    "source": "endpoint",
    "endpoint": "/ui-config",
    "required": true,
    "editable_fields": [
      "host",
      "alias",
      "webhook_secret",
      "source_name"
    ],
    "runtime_fields": [
      "id",
      "config_id",
      "container_id",
      "device_id"
    ],
    "identity_fields": [
      "host"
    ]
  },
  "identity": {
    "fields": [
      "host"
    ]
  },
  "capabilities": {
    "connected": {
      "kind": "sensor",
      "unit": "bool"
    },
    "temperature_c": {
      "kind": "sensor",
      "unit": "C"
    },
    "refresh": {
      "kind": "action"
    },
    "webhook_events_total": {
      "kind": "sensor",
      "unit": "events"
    },
    "last_event_age_seconds": {
      "kind": "sensor",
      "unit": "s"
    },
    "replay_webhook": {
      "kind": "action"
    }
  },
  "commands": {
    "refresh": {
      "description": "Refresh the device state.",
      "timeout_ms": 5000
    },
    "replay_webhook": {
      "description": "Replay the latest received webhook payload.",
      "timeout_ms": 10000
    }
  },
  "entities": [
    {
      "id": "demo-device",
      "name": "Demo Device",
      "device_id": "demo-device",
      "entity_type": "sensor",
      "capabilities": [
        "connected",
        "temperature_c",
        "refresh",
        "webhook_events_total",
        "last_event_age_seconds",
        "replay_webhook"
      ],
      "available_commands": [
        {
          "id": "refresh",
          "label": "Refresh",
          "kind": "action"
        },
        {
          "id": "replay_webhook",
          "label": "Replay Webhook",
          "kind": "action"
        }
      ],
      "dashboard": {
        "allowed_widgets": [
          "tile",
          "stat",
          "button"
        ],
        "default_widget": "tile"
      }
    }
  ]
}
